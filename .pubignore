# Files to exclude from pub.dev publishing
# (but keep in git repository)

# Build outputs
build/
example/build/

# Generated documentation (too large for pub.dev, available on GitHub)
doc/

# IDE files
*.iml
.idea/

# Scripts (not needed by package users)
scripts/

# Backup files from publish workflow
*.github_full

# Files that are gitignored but checked in (pub.dev warning)
dartdoc_options.yaml
doc/doc_assets/
